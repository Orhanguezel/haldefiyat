{
  "name": "hal-fiyatlari-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun x tsc -p tsconfig.json && node scripts/fix-build.mjs",
    "start": "node --experimental-specifier-resolution=node dist/index.js",
    "start:bun": "bun dist/index.js",
    "typecheck": "bun x tsc --noEmit",
    "db:seed": "bun src/db/seed/index.ts",
    "db:seed:nodrop": "bun src/db/seed/index.ts --no-drop",
    "db:seed:only": "bun src/db/seed/index.ts --only="
  },
  "dependencies": {
    "@agro/shared-backend": "workspace:*",
    "@agro/shared-types": "workspace:*",
    "@fastify/busboy": "^3.0.0",
    "@fastify/cookie": "^11",
    "@fastify/cors": "^11",
    "@fastify/deepmerge": "^3.0.0",
    "@fastify/error": "^4.2.0",
    "@fastify/jwt": "^10",
    "@fastify/multipart": "^9",
    "@fastify/mysql": "^5.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@lukeed/ms": "^2.0.2",
    "@sentry/node": "^10.45.0",
    "argon2": "^0.44.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.6",
    "fast-jwt": "^6.0.2",
    "fastify": "^5",
    "fastify-plugin": "^5.0.1",
    "mnemonist": "^0.40.0",
    "mysql2": "^3.15.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "secure-json-parse": "^4.0.0",
    "steed": "^1.1.3",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "20",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.15",
    "bun-types": "^1.3.1",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "typescript": "5"
  }
}
