# HaldeFiyat Backend — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın: cp .env.example .env

NODE_ENV=production
PORT=8091

# Veritabanı
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=app
DB_PASSWORD=
DB_NAME=hal_fiyatlari

# Güvenlik
JWT_SECRET=change-me-in-production-min-32-chars
COOKIE_SECRET=change-me-in-production-min-32-chars

# CORS (frontend URL'leri, virgülle ayır)
CORS_ORIGIN=https://haldefiyat.com

# Bildirimler
TELEGRAM_BOT_TOKEN=
# Inbound interactive bot için (Telegram setWebhook secret_token)
TELEGRAM_WEBHOOK_SECRET=
# Yeni ilan moderasyon uyarisinin gidecegi admin chat id (bos ise bildirim atlanir)
TELEGRAM_ADMIN_CHAT_ID=
# Bot setWebhook çağrısında kullanılan public taban URL (örn. https://haldefiyat.com)
PUBLIC_BASE_URL=https://haldefiyat.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@haldefiyat.com

# Depolama
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/var/www/tarim-dijital-ekosistem/projects/hal-fiyatlari/backend/uploads
LOCAL_STORAGE_BASE_URL=/uploads
PUBLIC_URL=https://haldefiyat.com

# Sentry (opsiyonel)
SENTRY_DSN=

# ── ETL ─────────────────────────────────────────────────────────────────────
# Cron zamanlaması (UTC); Istanbul'da UTC+3 sabit olduğu için UTC en basit.
ETL_CRON_SCHEDULE=30 7 * * *
ALERTS_CRON_SCHEDULE=45 7 * * *
ETL_CRON_TIMEZONE=UTC
# Kaynak bugün için veri dönmezse kaç gün geriye tarasın
ETL_MAX_DATE_FALLBACK_DAYS=7
# Bilinmeyen ürünleri otomatik hf_products'a eklesin mi
ETL_AUTO_REGISTER_PRODUCTS=true
ETL_REQUEST_TIMEOUT_MS=30000
# Migros perakende ETL (zincir direct scrape) — 12:00 TRT
# MIGROS_CRON_SCHEDULE=0 9 * * *
# marketfiyati.org.tr çoklu zincir ETL (a101, bim, carrefour, migros, tarim_kredi) — 12:30 TRT
# MARKETFIYATI_CRON_SCHEDULE=30 9 * * *
# Haftalık analiz yazısı üretimi — Pazartesi 09:20 TRT
# WEEKLY_ANALYSIS_CRON_SCHEDULE=20 6 * * 1
# Aylik TCMB EVDS (TÜFE/Yi-ÜFE) sync — ayın 5'i 13:00 TRT
# INFLATION_CRON_SCHEDULE=0 10 5 * *
# TCMB EVDS API key — https://evds2.tcmb.gov.tr (ücretsiz kayıt)
# EVDS_API_KEY=
# Pro Tier API rate limit (gunluk istek)
# API_KEY_FREE_DAILY_LIMIT=100
# API_KEY_PRO_DAILY_LIMIT=10000
# PRO_PRICE_MONTHLY_TL=99

# ── ETL kaynakları (config/etl-sources.ts'te varsayılanlar tanımlı) ─────────
# Aşağıdakiler yalnızca varsayılanı override etmek istediğinizde set edilir.
# HF_SOURCE_IZMIR_SEBZEMEYVE_ENABLED=true
# HF_SOURCE_IZMIR_SEBZEMEYVE_BASE_URL=https://openapi.izmir.bel.tr
# HF_SOURCE_IZMIR_SEBZEMEYVE_ENDPOINT=/api/ibb/halfiyatlari/sebzemeyve/{date}
# HF_SOURCE_IZMIR_SEBZEMEYVE_MARKET_SLUG=izmir-hal
#
# HF_SOURCE_IZMIR_BALIK_ENABLED=true
# HF_SOURCE_IZMIR_BALIK_ENDPOINT=/api/ibb/halfiyatlari/balik/{date}
#
# HF_SOURCE_IBB_ENABLED=false

# Twitter/X otomatik paylasim — @haldefiyat hesabi OAuth 1.0a
# https://developer.twitter.com/ → app → Keys and tokens
# 4 token zorunlu (Bearer Token kullanmiyoruz — OAuth 1.0a yeterli)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=
# IndexNow — Bing/Copilot aninda indexleme (bos birakilirsa devre disi)
INDEXNOW_KEY=
# Opsiyonel: ping URL tabani (varsayilan FRONTEND_URL)
INDEXNOW_SITE_URL=

# --- SMS / OTP (ilan-ver telefon dogrulama) ---
# Saglayici: none (dev, kod log'lanir) | netgsm
SMS_PROVIDER=none
# Netgsm panelinden: usercode/password + onayli msgheader (gonderici basligi)
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=
# NETGSM_ENDPOINT=https://api.netgsm.com.tr/sms/send/get

# --- Iyzico (ilan one cikarma odemesi — paketteki shared payments modulu) ---
# Kredansiyel girilmeden FEATURE_IYZICO_PAYMENT=false birak → endpoint 503 doner.
FEATURE_IYZICO_PAYMENT=false
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Test: https://sandbox-api.iyzipay.com  |  Canli: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
